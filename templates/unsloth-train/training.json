{
  "model": {
    "name": "unsloth/Qwen2.5-7B-Instruct-bnb-4bit",
    "max_seq_length": 2048,
    "load_in_4bit": true,
    "dtype": null,
    "trust_remote_code": false,
    "hf_token_env": "HF_TOKEN"
  },
  "dataset": {
    "source": "huggingface",
    "name": "NousResearch/hermes-function-calling-v1",
    "config": "func-calling-singleturn",
    "split": "train",
    "format": "sharegpt",
    "conversations_field": "conversations",
    "max_examples": 2000
  },
  "lora": {
    "rank": 16,
    "alpha": 16,
    "dropout": 0,
    "bias": "none",
    "gradient_checkpointing": "unsloth",
    "use_rslora": false,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "training": {
    "per_device_train_batch_size": 2,
    "gradient_accumulation_steps": 4,
    "warmup_steps": 5,
    "num_train_epochs": 1,
    "max_steps": 60,
    "learning_rate": 0.0002,
    "logging_steps": 1,
    "save_steps": 25,
    "save_total_limit": 2,
    "optim": "adamw_8bit",
    "weight_decay": 0.001,
    "lr_scheduler_type": "linear",
    "packing": false,
    "report_to": "tensorboard",
    "bf16": false,
    "fp16": false
  },
  "runtime": {
    "run_name": "qwen25-7b-function-calling-qlora",
    "seed": 3407,
    "output_dir": "outputs/current",
    "latest_checkpoint_dir": "checkpoints/latest",
    "final_checkpoint_dir": "checkpoints/final",
    "logs_dir": "logs",
    "exports_dir": "exports",
    "tensorboard": {
      "enabled": true
    }
  }
}
